# apps/web/.env.example
# Copy to apps/web/.env.local and fill in. Never commit .env.local.

# ── Supabase ────────────────────────────────────────────────────────────────
# Use the Shared Pooler connection string (port 6543) for the app + drizzle-kit
# generate/push. The direct connection (port 5432) is only for some migration
# scenarios. Project Settings → Database → Connection String.
DATABASE_URL=postgresql://postgres.[REF]:[PASSWORD]@[HOST]:6543/postgres

# ── Spotify OAuth (Authorization Code + PKCE) ───────────────────────────────
# PKCE does NOT use a client secret — only the Client ID is needed.
# IMPORTANT: Spotify no longer accepts http://localhost redirect URIs. Use the
# loopback IP 127.0.0.1. This value must match the dashboard entry EXACTLY.
SPOTIFY_CLIENT_ID=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/spotify/callback

# Space-separated scopes requested at login.
SPOTIFY_SCOPES=user-read-currently-playing user-read-email user-read-private

# ── Session ─────────────────────────────────────────────────────────────────
JWT_SECRET=                 # min 32 chars, random (openssl rand -base64 32)
JWT_EXPIRES_IN=7d

# ── App ─────────────────────────────────────────────────────────────────────
# Use 127.0.0.1 (not localhost) to match the Spotify redirect URI origin.
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
